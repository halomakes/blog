<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - haley</title>
    <script type="application/javascript" crossorigin src="~/dist/main.es.js"
            asp-append-version="true" async></script>
    <link rel="stylesheet" crossorigin href="~/dist/theme.css" asp-append-version="true" media="print"
          onload="this.media='all'">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Cascadia+Code:ital,wght@0,200..700;1,200..700&family=Montserrat:ital,wght@0,100..900;1,100..900&display=swap"
        rel="stylesheet" media="print" onload="this.media='all'">
</head>
<body>
<header>
    <nav>
        <span class="title">
            <span class="selector">
                    <span class="selected">blog</span>
                <span class="options">
                    <a href="https://blog.haley.casa">blog</a>
                    <a href="https://www.alexgriffith.me">www</a>
                    <a href="https://youtube.halomak.es">yt</a>
                </span>
            </span>
            <span class="dot">.</span>
            <span class="domain">haley</span>
            <span class="dot">.</span>
            <span class="tld">contact</span>
        </span>
        <span class="areas">
            <a href="#">recent</a>
            <a href="#">tags</a>
        </span>
    </nav>
</header>
<div class="container">
    <main role="main" class="pb-3">
        @RenderBody()
    </main>
</div>

<footer>
    <div class="container">
        &copy; @DateTime.Now.Year
        <br/>
        this site is powered by sleep-deprived brain cells
    </div>
</footer>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>